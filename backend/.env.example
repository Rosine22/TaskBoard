DB_TYPE=sqljs
DB_FILE=taskboard.sqlite

# Optional: switch to PostgreSQL instead of the default local file database
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=your_postgres_password
# DB_NAME=taskboard

# Optional: use full URL instead of the DB_* variables above
# DATABASE_URL=postgres://postgres:your_postgres_password@localhost:5432/taskboard
